HOST=127.0.0.1
PORT=43101
DATA_DIR=./data

# In deployed environments, point DATA_DIR at mounted persistent storage so
# wallet-bound identity anchors and verification summaries survive restarts.

# Comma-separated frontend origins allowed to call the gateway.
CORS_ORIGINS=http://127.0.0.1:43100,http://127.0.0.1:43102,http://127.0.0.1:43103,http://127.0.0.1:43105,https://aadharcha.in,https://ondcbuyer.aadharcha.in,https://ondcseller.aadharcha.in,https://flatwatch.aadharcha.in

CLAUDE_AGENT_AUTH_MODE=local_cli
CLAUDE_AGENT_ALLOW_LOCAL_CLI_AUTH=true

# Set this only on a trusted deployed gateway host that already has Claude Code installed
# and authenticated with your Claude Code OAuth session.
CLAUDE_AGENT_ALLOW_DEPLOYED_CLI_AUTH=false
CLAUDE_AGENT_MODEL=claude-haiku-4-5-20251001
CLAUDE_CODE_EXECUTABLE=
