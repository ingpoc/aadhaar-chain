# Cursor SDK (agent runtime)
CURSOR_API_KEY=
CURSOR_AGENT_MODEL=composer-2.5

# OpenAI Realtime voice (Buyer M12) — never put in Vite
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini

# Social / booth principal (AgentGuard host identity — not wallet)
# Production IdP: Auth0 Authorization Code Flow
# https://auth0.com/docs/get-started/authentication-and-authorization-flow/authorization-code-flow
# Auth0 Application type: Regular Web Application (confidential client secret on gateway only)
#
# Auth0 dashboard — paste ALL of these (comma-separated where noted):
# Allowed Callback URLs:
#   http://127.0.0.1:43101/api/auth/auth0/callback,
#   https://identity-aadhar-gateway-main.onrender.com/api/auth/auth0/callback,
#   https://gateway.aadharcha.in/api/auth/auth0/callback
# Allowed Logout URLs:
#   http://127.0.0.1:43102,http://127.0.0.1:43103,
#   http://localhost:43102,http://localhost:43103,
#   https://ondcbuyer.aadharcha.in,https://ondcseller.aadharcha.in
# Allowed Web Origins:
#   http://127.0.0.1:43102,http://127.0.0.1:43103,
#   http://localhost:43102,http://localhost:43103,
#   https://ondcbuyer.aadharcha.in,https://ondcseller.aadharcha.in
#
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
# Leave empty to default to {PUBLIC_GATEWAY_URL}/api/auth/auth0/callback
AUTH0_REDIRECT_URI=
# Local booth: AUTH_DEMO_CONTINUE=true. Staging/production: forced off unless AUTH_DEMO_CONTINUE_FORCE=true.
AUTH_DEMO_CONTINUE=true
AUTH_DEMO_CONTINUE_FORCE=
# Optional legacy direct Google (prefer enabling Google as an Auth0 connection instead)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Local: http://127.0.0.1:43101
# Deployed gateway: https://gateway.aadharcha.in (onrender subdomain kept as backup)
PUBLIC_GATEWAY_URL=http://127.0.0.1:43101
# demo | staging | production — staging/production force-off booth demo
AADHAAR_CHAIN_ENV=demo
# Comma-separated SPA origins (CORS + OAuth return allowlist). Include localhost + FQDNs.
CORS_ORIGINS=http://127.0.0.1:43100,http://127.0.0.1:43102,http://127.0.0.1:43103,http://127.0.0.1:43105,http://localhost:43100,http://localhost:43102,http://localhost:43103,http://localhost:43105,https://aadharcha.in,https://www.aadharcha.in,https://ondcbuyer.aadharcha.in,https://ondcseller.aadharcha.in,https://flatwatch.aadharcha.in

# ONDC participant (server-side secrets — never put signing keys in Vite)
# PreProd: set ONDC_ENABLED=true after Buyer PEM + uk_id on host. Defaults below.
ONDC_ENABLED=false
ONDC_SUBSCRIBER_ID=ondcbuyer.aadharcha.in
ONDC_BAP_ID=ondcbuyer.aadharcha.in
ONDC_BAP_URI=https://ondcbuyer.aadharcha.in/ondc
ONDC_GATEWAY_URL=https://preprod.gateway.ondc.org/search
ONDC_REGISTRY_URL=https://preprod.registry.ondc.org/v2.0/lookup
ONDC_SIGNING_PRIVATE_KEY_PATH=
ONDC_ENCRYPTION_PRIVATE_KEY_PATH=
ONDC_UNIQUE_KEY_ID=
# Onboarding hosts (site verification + /ondc/on_subscribe)
# Portal UI path is PreProd Subscribed — set preprod before live FQDN challenges.
ONDC_REGISTRY_ENV=preprod
ONDC_BUYER_SUBSCRIBER_ID=ondcbuyer.aadharcha.in
ONDC_SELLER_SUBSCRIBER_ID=ondcseller.aadharcha.in
# Optional overrides. Defaults: preprod → .local/ondc-sandbox/portal-download/{role}
# (from Downloads keys.json=Buyer, keys (1).json / key1=Seller); else local DER sandbox.
ONDC_BUYER_KEYS_DIR=
ONDC_SELLER_KEYS_DIR=
ONDC_KEYS_SOURCE=auto
# Render/prod: inject portal PEMs via env (ephemeral disk). Prefer *_PEM_B64.
# ONDC_BUYER_SIGNING_PRIVATE_PEM_B64=
# ONDC_BUYER_ENCRYPTION_PRIVATE_PEM_B64=
# ONDC_BUYER_REQUEST_ID=
# ONDC_BUYER_UNIQUE_KEY_ID=
# ONDC_SELLER_SIGNING_PRIVATE_PEM_B64=
# ONDC_SELLER_ENCRYPTION_PRIVATE_PEM_B64=
# ONDC_SELLER_REQUEST_ID=
# ONDC_SELLER_UNIQUE_KEY_ID=
# ONDC_ENV_KEYS_DIR=/tmp/ondc-env
#
# Render Free ephemeral storage (required — appuser cannot write ./data; no Disk):
# DATA_DIR=/tmp/aadharchain-data
# ONDC_ENV_KEYS_DIR=/tmp/ondc-env
# Also set HTTP health check path /health (or /api/health) in Render Settings.


# Setu.co Aadhaar eKYC (preferred production KYC rail)
# Docs: https://docs.setu.co/data/ekyc/quickstart
# Sandbox dashboard: create product instance → copy headers below
SETU_EKYC_ENABLED=false
SETU_EKYC_BASE_URL=https://dg-sandbox.setu.co
SETU_EKYC_CLIENT_ID=
SETU_EKYC_CLIENT_SECRET=
SETU_EKYC_PRODUCT_INSTANCE_ID=
# Public URLs Setu can reach (use ngrok/tunnel for local webhook testing)
PUBLIC_WEB_URL=http://127.0.0.1:43100
